#!/usr/bin/env zsh

_gb_gh_st() {
  local -r default_handle="${USER}"

  local closed=false
  if [[ "${1}" == "--closed" ]]; then
    closed=true
    shift
  fi


  for br in "${(@f)$(git branch --format '%(refname:lstrip=2)' --list)}"; do
    gh_ref="$(gb-gh -q "${br}")"
    if [[ -z "${gh_ref}" || "${gh_ref}" == *${default_handle}* ]]; then
      continue
    fi
    # echo -n "${br} -> ${gh_ref}"
    # echo -n "${br}\t"
    # pipe into cat to force non-interactive
    result=$(gh pr st "${gh_ref}")
    if $closed && [[ $result != CLOSED* ]]; then
      continue
    fi
    echo "${br}\t${result}"
  done
}

# gh-st-all | column -t -l4 --table-truncate=4
# gh-st-all --closed
# gh-st-all --closed | tee /dev/tty | cut -f1 | xargs -n1 -p git branch --delete
# gh-st-all --closed | cut -f1 | xargs -n1 gb-gh | tee /dev/tty | cut -f1 | xargs -p git branch --delete --force
_gb_gh_st $@
