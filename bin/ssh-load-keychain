#!/usr/bin/env zsh

set -ue

LOGFILE=~/Library/Logs/ssh-load-keychain.log

/bin/date "+%Y-%m-%d %H:%M:%S" >> "${LOGFILE}"
/usr/bin/ssh-add --apple-load-keychain >>& "${LOGFILE}"
echo >> "${LOGFILE}"

# lk $ZSH_SERGII/bin/LaunchAgents/ssh-load-keychain.plist ~/Library/LaunchAgents
# launchctl load -w ~/Library/LaunchAgents/ssh-load-keychain.plist
# launchctl list org.sergii.ssh-load-keychain

# ssh-add -l to list ssh authentication agent keys (-L) for full keys
# ssh-add -L for full keys
# ssh -v -T git@github.com to check what key ssh chooses for authentication
# ssh -G host to print the final config for the host without connecting
# ssh-keygen -l -f ~/.ssh/key.pub - check key type, bit length, and fingerprint
# ssh-keygen -y -P "" -f ~/.ssh/key &> /dev/null && echo "Unencrypted" || echo "Passphrase Protected"
